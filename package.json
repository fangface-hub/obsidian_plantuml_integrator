{
  "name": "obsidian-plantuml-integrator",
  "version": "1.0.0",
  "description": "Obsidian plugin to render PlantUML from code blocks and .puml files",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint main.ts --max-warnings=0",
    "lint:fix": "eslint main.ts --fix --max-warnings=0",
    "generate:release-notes": "node scripts/generate-release-notes.mjs",
    "version:major": "node scripts/bump-major-version.mjs",
    "version:minor": "node scripts/bump-minor-version.mjs",
    "version:patch": "node scripts/bump-patch-version.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "plantuml"
  ],
  "author": "fangface",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "^1.8.9",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "plantuml-encoder": "^1.4.0"
  }
}
